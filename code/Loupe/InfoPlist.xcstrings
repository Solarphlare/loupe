          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe читає дані про маршрутизацію мікрофона та його джерела. Аудіо ніколи не записується."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe 会读取麦克风的路由信息和数据源。它从不录制音频。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe 會讀取麥克風的路由資訊和資料來源。它從不錄製音訊。"
          }
        }
      }
    },
    "NSMotionUsageDescription" : {
      "comment" : "Motion & Fitness permission prompt. Shown when Loupe samples motion sensors and reads today's pedometer totals.",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يقرأ Loupe بيانات الحركة بصمت."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe liest Bewegungssensoren und die heutigen Schrittwerte aus, um Verhaltenssignale zu zeigen. Es wird nichts gesendet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe samples motion sensors and reads today's pedometer totals to show behavioral signals. Nothing is sent anywhere."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe toma muestras de los sensores de movimiento y lee los totales del podómetro de hoy para mostrar señales de comportamiento. No se envía nada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe échantillonne les capteurs de mouvement et lit les totaux du podomètre du jour pour montrer des signaux comportementaux. Rien n'est envoyé."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupeは、行動シグナルを示すためにモーションセンサーをサンプリングし、当日の歩数計データを読み取ります。データはどこにも送信されません。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Loupe amostra sensores de movimento e lê os totais do pedômetro de hoje para mostrar sinais comportamentais. Nada é enviado para lugar nenhum."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Loupe amostra os sensores de movimento e lê os totais do podómetro de hoje para mostrar sinais comportamentais. Nada é enviado para qualquer lado."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe снимает показания датчиков движения и читает сегодняшние данные шагомера, чтобы показать поведенческие сигналы. Ничего никуда не отправляется."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe davranışsal sinyalleri göstermek için hareket sensörlerini örnekler ve bugünün adımölçer verilerini okur. Hiçbir şey gönderilmez."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe знімає показники датчиків руху й читає сьогоднішні дані крокоміра, щоб показати поведінкові сигнали. Нічого нікуди не надсилається."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe 会采样运动传感器，并读取当天的计步器数据，用于展示行为信号。不会向外发送任何数据。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe 會取樣動作感測器，並讀取當天的計步器資料，用來呈現行為訊號。不會向外傳送任何資料。"
          }
        }
      }
    },
    "NSPhotoLibraryUsageDescription" : {
      "comment" : "Photos permission prompt. Shown when Loupe counts photo library assets and collections — it never reads image data.",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يقرأ Loupe بيانات مكتبة الصور الخاصة بك بصمت."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe zählt Objekte und Sammlungen in deiner Fotomediathek. Bilddaten werden nie gelesen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe counts photo library assets and collections. It never reads image data."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe cuenta los elementos y las colecciones de tu fototeca. Nunca lee los datos de las imágenes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe compte les éléments et les collections de votre photothèque. Il ne lit jamais les données d'image."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupeは、写真ライブラリのアイテム数とコレクション数を集計します。画像データを読み取ることはありません。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Loupe conta os itens e as coleções da sua fototeca. Nunca lê os dados das imagens."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Loupe conta os itens e as coleções da sua biblioteca de fotografias. Nunca lê os dados das imagens."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe считает объекты и альбомы в твоей медиатеке Фото. Сами изображения не читаются."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe fotoğraf kütüphanesindeki öğeleri ve koleksiyonları sayar. Görüntü verilerini hiçbir zaman okumaz."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe рахує об'єкти й альбоми у твоїй медіатеці Фото. Самі зображення не читаються."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe 会统计照片图库中的项目和合集数量。它从不读取图像数据。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe 會統計照片圖庫中的項目和相簿數量。它從不讀取影像資料。"
          }
        }
      }
    },
    "NSRemindersFullAccessUsageDescription" : {
      "comment" : "Reminders (full access) permission prompt. Shown when Loupe counts reminder lists, list titles, and incomplete reminders.",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يقرأ Loupe حسابات التذكيرات الخاصة بك بصمت."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe zählt Erinnerungslisten, zeigt Listentitel und zählt offene Erinnerungen. Einzelne Erinnerungstitel und Notizen werden nicht angezeigt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe counts reminder lists, shows list titles, and counts incomplete reminders. It does not display reminder titles or notes."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe cuenta las listas de recordatorios, muestra sus títulos y cuenta los recordatorios sin completar. No muestra ni los títulos ni las notas de los recordatorios."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe compte les listes de rappels, affiche leurs titres et compte les rappels non terminés. Il n'affiche ni les titres ni les notes des rappels."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupeは、リマインダーのリスト数を集計し、リスト名を表示し、未完了のリマインダー数を集計します。リマインダーのタイトルやメモは表示しません。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Loupe conta listas de lembretes, mostra os títulos das listas e conta os lembretes não concluídos. Não mostra títulos nem notas dos lembretes."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Loupe conta listas de lembretes, mostra os títulos das listas e conta os lembretes por concluir. Não mostra títulos nem notas dos lembretes."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe считает списки напоминаний, показывает их названия и считает невыполненные напоминания. Названия и заметки самих напоминаний не показываются."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe anımsatıcı listelerini sayar, liste başlıklarını gösterir ve tamamlanmamış anımsatıcıları sayar. Anımsatıcı başlıklarını veya notları göstermez."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe рахує списки нагадувань, показує їхні назви та рахує невиконані нагадування. Назви й нотатки самих нагадувань не показуються."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe 会统计提醒事项列表、显示列表名称，并统计未完成的提醒事项数量。它不会显示提醒事项的标题或备注。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loupe 會統計提醒事項列表、顯示列表名稱，並統計未完成的提醒事項數量。它不會顯示提醒事項的標題或備註。"
          }
        }
      }
    }
  },
  "version" : "1.0"
}
