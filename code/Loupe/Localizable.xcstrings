          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Основне про фінгерпринтинг"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "指纹识别要点"
          }
        },
        "zh-Hant" : {
