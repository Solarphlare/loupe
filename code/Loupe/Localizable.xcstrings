          }
        }
      }
    },
    "Read from your %@'s region setting. A VPN does not change this." : {
      "comment" : "Caption beneath the region narrative card on the fingerprint summary sheet — explains where the claim came from. %@ is the device model name (e.g., iPhone, iPad).",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أُخذت القيمة من إعداد المنطقة لجهازك الـ%@. لا تستطيع شبكة VPN إخفاء ذلك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aus der Regionseinstellung deines %@s gelesen. Ein VPN ändert daran nichts."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leído desde el ajuste de región de tu %@. Una VPN no lo cambia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lu depuis le réglage de région de votre %@. Un VPN n'y change rien."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "お使いの%@の地域設定から読み取り。VPNを使っても変わりません。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
