    "Inferred from a time zone (%@) that doesn't match your %@'s region setting." : {
      "comment" : "Caption beneath the travel narrative card on the fingerprint summary sheet — explains where the claim came from. First %@ is the time-zone identifier (e.g., 'Europe/Berlin'); second %@ is the device model name (e.g., iPhone).",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يُستنتج من منطقة زمنية (%1$@) لا تتطابق مع إعداد منطقة %2$@."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abgeleitet aus einer Zeitzone (%1$@), die nicht zur Regionseinstellung deines %2$@ passt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Inferred from a time zone (%1$@) that doesn't match your %2$@'s region setting."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deducido de una zona horaria (%@) que no coincide con el ajuste de región de tu %@."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Déduit d'un fuseau horaire (%@) qui ne correspond pas au réglage de région de votre %@."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "お使いの%2$@の地域設定と一致しないタイムゾーン（%1$@）から推測。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inferido de um fuso horário (%@) que não combina com o ajuste de região do seu %@."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inferido a partir de um fuso horário (%@) que não corresponde à definição de região do seu %@."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
