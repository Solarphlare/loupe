          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Точно или приблизительно. Определяет, насколько подробно сообщаются координаты."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
