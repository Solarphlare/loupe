    "Increments each time the pasteboard changes. The same counter is visible to every app." : {
      "comment" : "Signal card rationale beneath the changeCount value.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يزداد في كل مرة تتغير فيها الحافظة. العداد نفسه مرئي لكل تطبيق."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erhöht sich bei jeder Änderung der Zwischenablage. Derselbe Zähler ist für jede App sichtbar."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aumenta cada vez que cambia el portapapeles. Todas las apps ven el mismo contador."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "S'incrémente à chaque modification du presse-papiers. Le même compteur est visible par toutes les apps."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ペーストボードが変わるたびに値が増えます。同じカウンターはどのAppからも見えます。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aumenta cada vez que a área de transferência muda. O mesmo contador fica visível para todos os apps."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aumenta sempre que a área de transferência muda. O mesmo contador está visível para todas as apps."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Увеличивается на единицу каждый раз, когда меняется содержимое буфера обмена. Этот счётчик доступен любому приложению."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pano her değiştiğinde artar. Aynı sayaç tüm uygulamalar tarafından görülebilir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Зростає щоразу, коли змінюється буфер обміну. Той самий лічильник видно кожному застосунку."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每次剪贴板内容变化时数字都会增加。任何 App 看到的都是同一个计数。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "剪貼板每次變更時就會遞增。任何 App 都看得到這同一個計數器。"
          }
        }
      }
    },
