    "Some readings are passively visible to apps with no prompt at all, while others require your permission." : {
      "comment" : "Onboarding page body — page 5, topic: the three sensitivity tiers Loupe organizes signals into.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بعض القيم متاحة لجميع التطبيقات دون الحاجة لطلب إذن منك، بينما يتطلب البعض الآخر إذنك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manche Werte sind für Apps ganz ohne Abfrage sichtbar, andere setzen deine Erlaubnis voraus."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Algunos valores son visibles para las apps de forma pasiva, sin ningún aviso, mientras que otros requieren tu permiso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Certaines valeurs sont visibles passivement par les apps, sans aucune invite, tandis que d'autres nécessitent votre autorisation."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "確認ダイアログなしでAppから受動的に見える値もあれば、許可が必要な値もあります。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alguns valores ficam visíveis para os apps de forma passiva, sem solicitação nenhuma, enquanto outros exigem sua permissão."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alguns valores ficam passivamente visíveis para as apps sem qualquer pedido, enquanto outros exigem a sua permissão."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Некоторые значения приложения видят пассивно, без всякого запроса; другие требуют твоего разрешения."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bazı değerler herhangi bir istem olmadan uygulamalara görünür, diğerleri ise senin iznini gerektirir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Одні значення застосунки бачать пасивно, без жодного запиту, інші — лише з твого дозволу."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有些读数 App 完全可以直接看到，根本不会有任何提示；另一些则需要你的授权。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有些讀數 App 不需任何提示就能被動取得，有些則需要你的權限。"
          }
        }
      }
    },
