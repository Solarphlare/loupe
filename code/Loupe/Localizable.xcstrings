    "Battery charge level and charging state. Changes slowly, so the value can persist across short sessions." : {
      "comment" : "Signal card rationale beneath the Battery level & state value.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مستوى شحن البطارية وحالة الشحن. يتغير ببطء، لذا يمكن أن تستمر القيمة عبر الجلسات القصيرة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Batterieladestand und Ladestatus. Ändert sich langsam, sodass der Wert über kurze Sitzungen hinweg gleich bleiben kann."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nivel de carga de la batería y estado de carga. Cambia lentamente, así que el valor puede mantenerse a lo largo de sesiones cortas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niveau de charge de la batterie et état de charge. Évolue lentement, la valeur peut donc persister d'une courte session à l'autre."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "バッテリーの充電量と充電状態。変化がゆっくりなため、短いセッションをまたいで値が変わらないこともあります。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nível de carga da bateria e estado de carregamento. Muda lentamente, então o valor pode persistir entre sessões curtas."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nível de carga e estado de carregamento da bateria. Varia lentamente, pelo que o valor pode persistir ao longo de sessões curtas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Уровень заряда и состояние зарядки. Меняется медленно, поэтому значение может сохраняться на протяжении коротких сессий."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pil şarj seviyesi ve şarj durumu. Yavaş değişir, bu yüzden değer kısa oturumlarda aynı kalabilir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Рівень заряду акумулятора та стан заряджання. Змінюється повільно, тож значення може зберігатися між короткими сеансами."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "电池电量和充电状态。变化缓慢，因此读数在短时间内可以保持不变。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
