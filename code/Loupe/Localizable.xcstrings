            "value" : "Geschickte Nutzung öffentlicher APIs, um mehr Details als eigentlich vorgesehen herauszuholen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usos ingeniosos de APIs públicas para extraer más detalles de los previstos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usages détournés d'API publiques pour en extraire plus que prévu."
