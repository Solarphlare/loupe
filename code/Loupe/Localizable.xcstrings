          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Valores de margen determinados por el notch o la Dynamic Island. Varían según el chasis del dispositivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Valeurs d'encart définies par l'encoche ou le Dynamic Island. Varient selon le châssis de l'appareil."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
