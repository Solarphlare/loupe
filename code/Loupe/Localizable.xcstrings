          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Виведено з часового поясу (%1$@), який не збігається з параметром регіону твого %2$@."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
