    "Free space on your %@. It changes slowly, so similar values across sessions can be correlated to one another." : {
      "comment" : "Signal card rationale beneath the Available capacity value. %@ is the device model name. Explains that free space is a near-stable user-specific identifier.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "المساحة الحرة على %@. تتغير ببطء، لذلك يمكن ربط القيم المتشابهة عبر الجلسات ببعضها البعض."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freier Speicher auf deinem %@. Dieser ändert sich langsam, deshalb lassen sich ähnliche Werte über mehrere Sitzungen hinweg miteinander in Verbindung bringen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Espacio libre en tu %@. Cambia lentamente, así que valores parecidos entre sesiones pueden correlacionarse entre sí."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Espace libre sur votre %@. Il évolue lentement, donc des valeurs proches d'une session à l'autre peuvent être recoupées entre elles."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "お使いの%@の空き容量。変化はゆっくりなので、セッションをまたいで似た値が現れると相互に紐づけられる可能性があります。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Espaço livre no seu %@. Muda lentamente, então valores parecidos em sessões diferentes podem ser correlacionados entre si."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Espaço livre no seu %@. Varia lentamente, por isso valores semelhantes em diferentes sessões podem ser correlacionados entre si."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Свободное место на твоём %@. Оно меняется медленно, поэтому близкие значения в разных сеансах можно сопоставить друг с другом."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ cihazındaki boş alan. Yavaşça değişir, bu yüzden oturumlar arasındaki benzer değerler birbiriyle ilişkilendirilebilir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вільне місце на твоєму %@. Воно змінюється повільно, тому близькі значення в різних сеансах можна співвіднести між собою."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的 %@ 上的可用空间。它变化得很慢，所以不同会话之间相近的数值可以互相关联。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的 %@ 上的可用空間。變化很慢，因此不同時間點相近的數值可以互相關聯起來。"
          }
        }
      }
    },
