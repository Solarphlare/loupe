    "ISO country code from your App Store account. Pins the account to a country regardless of where the %@ is right now." : {
      "comment" : "Signal card rationale beneath the App Store country value. %@ is the device model name (e.g., iPhone, iPad).",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ISO-Ländercode aus deinem App-Store-Account. Verankert das Konto in einem Land, unabhängig davon, wo sich das %@ gerade befindet."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Código de país ISO de tu cuenta de App Store. Asocia la cuenta a un país, sin importar dónde esté tu %@ ahora mismo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
