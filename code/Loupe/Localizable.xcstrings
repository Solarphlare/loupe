    "Precise or Reduced accuracy. Determines the granularity of reported coordinates." : {
      "comment" : "Signal card rationale beneath the Accuracy authorization value.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "دقة دقيقة أو منخفضة. يحدد مدى دقة الإحداثيات المبلغ عنها."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Präzise oder reduzierte Genauigkeit. Legt fest, wie fein die gemeldeten Koordinaten sind."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Precisión Exacta o Reducida. Determina el nivel de detalle de las coordenadas reportadas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Précision Précise ou Réduite. Détermine la granularité des coordonnées rapportées."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "正確な位置情報または概算の位置情報。報告される座標の精度を決めます。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
