          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lido a partir da hora de arranque do sistema, que é visível para qualquer app."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
