          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lido a partir da definição de região do seu %@. Uma VPN não altera este valor."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Прочитано из настройки региона твоего %@. VPN это не меняет."
          }
        },
        "tr" : {
          "stringUnit" : {
