        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قيم الهوامش الداخلية التي يحددها النتوء (Notch) أو الجزيرة التفاعلية (Dynamic Island). تختلف حسب هيكل الجهاز."
          }
        },
        "de" : {
