          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Твої списки нагадувань та облікові записи, з яких вони синхронізуються, можуть показати, на які сервіси й послуги ти покладаєшся."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
