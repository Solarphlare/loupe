    "Tapping Enable shows the %@ permission prompt. You can revoke access later in Settings." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يؤدي النقر على تمكين إلى إظهار مطالبة إذن %@. يمكنك إبطال الوصول لاحقًا في الإعدادات."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippst du auf „Aktivieren“, erscheint die Erlaubnis-Abfrage für %@. Den Zugriff kannst du später in den Einstellungen widerrufen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al tocar Activar aparece el aviso de permiso de %@. Puedes revocar el acceso más tarde en Ajustes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toucher Activer affiche la demande d'autorisation pour %@. Vous pourrez révoquer l'accès plus tard dans Réglages."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「有効にする」をタップすると、%@の許可ダイアログが表示されます。アクセスはあとから設定で取り消せます。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tocar em Ativar exibe a solicitação de permissão de %@. Você pode revogar o acesso depois nos Ajustes."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ao tocar em Ativar, surge o pedido de autorização de %@. Pode revogar o acesso mais tarde nas Definições."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "При нажатии «Включить» появится системный запрос разрешения для %@. Доступ можно отозвать позже в Настройках."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Etkinleştir'e dokunduğunda %@ izin istemi görünür. Erişimi daha sonra Ayarlar'dan kaldırabilirsin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Натискання «Увімкнути» покаже запит дозволу %@. Скасувати доступ можна пізніше в Параметрах."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "点按“启用”会弹出 %@ 权限提示。你之后可以在“设置”中撤销访问权限。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "點一下「啟用」會跳出 %@ 的權限提示。你之後可以在「設定」裡撤銷權限。"
          }
        }
      }
    },
