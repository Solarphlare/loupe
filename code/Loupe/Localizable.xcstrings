    "Stays the same across every app from the same developer, until you uninstall all of them." : {
      "comment" : "Signal card rationale beneath the identifierForVendor value.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يبقى كما هو عبر كل تطبيق من نفس المطور، حتى تقوم بإلغاء تثبيتها جميعًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bleibt in allen Apps desselben Entwicklers gleich, bis du sie alle deinstallierst."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es el mismo en todas las apps del mismo desarrollador, hasta que las desinstalas todas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reste identique pour toutes les apps du même développeur, jusqu'à ce que vous les désinstalliez toutes."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "同じ開発元のすべてのAppで同じ値になり、それらをすべて削除するまで変わりません。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permanece o mesmo em todos os apps do mesmo desenvolvedor, até você desinstalar todos eles."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantém-se igual em todas as apps do mesmo programador, até desinstalar todas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Остаётся неизменным для всех приложений одного разработчика, пока ты не удалишь их все."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aynı geliştiricinin tüm uygulamalarında aynı kalır, hepsini silene kadar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Залишається однаковим для всіх застосунків того самого розробника, доки ти не видалиш їх усі."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在同一开发者的每个 App 之间保持一致，直到你卸载该开发者的所有 App。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在同一位開發者的所有 App 中都保持不變，除非你把它們全部解除安裝。"
          }
        }
      }
