    "When your %@ last booted. Stays the same until the next restart." : {
      "comment" : "Signal card rationale beneath the Boot time value. %@ is the device model name (e.g., iPhone, iPad).",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
