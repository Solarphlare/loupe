          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App StoreアカウントのISO国コード。お使いの%@が現在どこにあっても、アカウントは特定の国に紐づきます。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
