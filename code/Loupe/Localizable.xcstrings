        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "O Loupe lê tudo isso no seu %@ e mantém aqui. Nada é enviado, sincronizado ou compartilhado, a menos que você escolha exportar."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "O Loupe lê tudo isto no seu %@ e guarda-o aqui. Nada é carregado, sincronizado ou partilhado, a menos que opte por exportar."
          }
