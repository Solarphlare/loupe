    "The DNS hostname. On some setups, it matches the name you've given your %@." : {
      "comment" : "Signal card rationale beneath the kern.hostname value. %@ is the device model name (e.g., iPhone, iPad).",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
