    "%@ shows a prompt the first time an app asks." : {
      "comment" : "Sensitivity tier description shown in onboarding and as the footer beneath the signal list on every permissioned-tier category screen. %@ is the OS name (iOS, iPadOS, macOS).",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يعرض %@ مطالبة في أول مرة يطلب فيها تطبيق ما ذلك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ zeigt beim ersten Versuch einer App eine Anfrage."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ muestra un aviso la primera vez que una app lo pide."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ affiche une demande la première fois qu'une app le demande."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appが初めて要求したとき、%@は確認ダイアログを表示します。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O %@ exibe uma solicitação na primeira vez que um app pede."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O %@ apresenta um pedido na primeira vez que uma app pergunta."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ показывает запрос, когда приложение запрашивает доступ впервые."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ bir uygulama ilk kez istediğinde bir bildirim gösterir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ показує запит, коли застосунок звертається вперше."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 会在 App 首次询问时弹出系统提示。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 會在 App 第一次要求時顯示提示。"
          }
        }
      }
    },
