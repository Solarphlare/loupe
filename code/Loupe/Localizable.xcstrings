          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aus dem Erstellungsdatum des Speichervolumens gelesen. Wie viele andere %@-Geräte wurden wohl in genau derselben Sekunde eingerichtet?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leído desde la fecha de creación del volumen de almacenamiento. ¿Cuántos otros %@ crees que se configuraron en ese mismo segundo?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lu depuis la date de création du volume de stockage. Combien d'autres %@ pensez-vous ont été configurés à cette seconde précise ?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ストレージボリュームの作成日時から読み取り。同じ秒にセットアップされた%@はほかにどれだけあると思いますか？"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lido da data de criação do volume de armazenamento. Quantos outros aparelhos %@ você acha que foram configurados exatamente naquele mesmo segundo?"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lido a partir da data de criação do volume de armazenamento. Quantos outros dispositivos %@ acha que foram configurados nesse segundo exato?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Прочитано из даты создания тома хранилища. Сколько ещё устройств %@, как ты думаешь, было настроено в ту же самую секунду?"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Depolama biriminin oluşturulma tarihinden okunur. Sence tam o saniyede başka kaç %@ kurulmuş olabilir?"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Прочитано з дати створення тому сховища. Як ти думаєш, скільки інших пристроїв %@ налаштували саме в ту секунду?"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "读取自存储卷的创建日期。你觉得还有多少台 %@ 是在那同一秒完成设置的？"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "讀取自儲存空間的建立日期。你覺得還有多少其他 %@ 裝置剛好也在那一秒完成設定？"
          }
        }
      }
    },
    "Read from the system's boot time, which is visible to any app." : {
      "comment" : "Caption beneath the uptime narrative card on the fingerprint summary sheet — explains where the claim came from.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يُقرأ من وقت بدء تشغيل النظام، وهو مرئي لأي تطبيق."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aus der Startzeit des Systems gelesen, die für jede App sichtbar ist."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leído desde la hora de arranque del sistema, visible para cualquier app."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lu depuis l'heure de démarrage du système, visible par n'importe quelle app."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "システムの起動時刻から読み取り。どのAppからも見える値です。"
