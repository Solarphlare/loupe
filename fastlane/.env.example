# App Store Connect API credentials for fastlane.
#
# Copy this file to `fastlane/.env` and fill in your values.
# fastlane loads `fastlane/.env` automatically. NEVER commit the real
# `.env` or the `.p8` key file — both are gitignored.
#
# Create a key at:
#   App Store Connect -> Users and Access -> Integrations -> App Store Connect API
# Give it the "App Manager" role so it can edit metadata.

# The Key ID shown next to the key (10 characters).
ASC_KEY_ID=YOUR_KEY_ID

# The Issuer ID shown at the top of the Integrations page (a UUID).
ASC_ISSUER_ID=YOUR_ISSUER_ID

# Path to the downloaded private key. You can only download it once.
# Keep it out of git (e.g. inside fastlane/, which ignores *.p8).
ASC_KEY_FILEPATH=./fastlane/AuthKey_YOUR_KEY_ID.p8

# Optional — only if you authenticate with an Apple ID instead of an API key,
# or your account belongs to more than one team:
# FASTLANE_APPLE_ID=you@example.com
# FASTLANE_ITC_TEAM_ID=
# FASTLANE_TEAM_ID=
